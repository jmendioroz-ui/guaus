<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Guau - Creando Familias</title>
<link href="https://fonts.googleapis.com/css2?family=Palenquin:wght@400;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; background:#F5A020; overflow:hidden; }
.screen { position:fixed; inset:0; width:100%; height:100%; }
.bg { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top; }
.content {
  position:absolute; inset:0;
  display:flex; flex-direction:column; align-items:center;
  padding: max(env(safe-area-inset-top, 60px), 60px) 32px max(env(safe-area-inset-bottom, 48px), 48px);
}
.logo { width:55%; max-width:220px; margin-bottom:20px; }
.tagline {
  font-family:'Palenquin', sans-serif;
  font-size:27px; text-align:center; color:#1a1a1a;
  line-height:1.45; font-weight:400; margin-bottom:auto;
}
.tagline strong { font-weight:700; }
.bottom { width:100%; display:flex; flex-direction:column; align-items:center; gap:16px; }
.btn-crear {
  width:88%; max-width:320px;
  background:#ffffff; border:none; border-radius:50px;
  padding:18px 32px;
  font-family:'Palenquin', sans-serif; font-size:15px; font-weight:700;
  color:#1a1a1a; letter-spacing:1.5px; text-transform:uppercase;
  cursor:pointer; box-shadow:0px 8px 24px rgba(0,0,0,0.30);
}
.btn-login {
  font-family:'Palenquin', sans-serif; font-size:17px; font-weight:600;
  color:#ffffff; background:none; border:none; cursor:pointer;
}
.help-btn { position:absolute; bottom:max(env(safe-area-inset-bottom, 28px), 28px); right:22px; width:38px; height:38px; cursor:pointer; }
</style>
</head>
<body>
<div class="screen">
  <img class="bg" src="data:image/png;base64," alt="">
  <div class="content">
    <img class="logo" src="data:image/png;base64," alt="Guaus">
    <p class="tagline">Adoptá<br>Apadrina o<br>mimá a un <strong>perrito</strong><br>de refugio.</p>
    <div class="bottom">
      <button class="btn-crear">CREAR CUENTA GRATIS</button>
      <button class="btn-login">Iniciar sesión</button>
    </div>
  </div>
  <img class="help-btn" src="data:image/png;base64," alt="Ayuda">
</div>
</body>
</html>
